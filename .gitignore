*.o
*.d

# Assembled app bundle (built by Scripts/build.sh, not committed)
*.app/

# Runtime artifacts — created at launch, never committed
# Leading slash anchors the pattern to the repo root so it does NOT
# accidentally match Sources/NyctimeneCore/Config/ on case-insensitive APFS.
/data/
/config/
/.backup/

